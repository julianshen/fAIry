{
  "name": "@fairy/pi-daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fairy's standalone local agent daemon — spawns Pi, bridges browser tools, owns an isolated workspace + config.",
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsc --noEmit",
    "build:compile": "bun build src/main.ts --compile --outfile dist/fairy-daemon",
    "build:pi": "bun build node_modules/@earendil-works/pi-coding-agent/dist/cli.js --compile --outfile dist/fairy-pi"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
